@using SODP.UI.Services;
@using SODP.UI.Pages.ActiveProjects.ViewModels;

@model ProjectDetailsVM

@inject LanguageTranslatorFactory _translatorFactory;

<div>
	@if (!string.IsNullOrWhiteSpace(Model.Title))
	{
		<div>
			<label class="text-secondary">Nazwa zamierzenia budowlanego:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.Title</span>
			</div>
		</div>
	}	
	@if (!string.IsNullOrWhiteSpace(Model.Address))
	{
		<div>
			<label class="text-secondary">Adres:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.Address</span>
			</div>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(Model.LocationUnit))
	{
		<div>
			<label class="text-secondary">Jednostka ewidencyjna:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.LocationUnit</span>
			</div>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(Model.BuildingCategory))
	{
		<div>
			<label class="text-secondary">Kategoria obiektu budowlanego:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.BuildingCategory</span>
			</div>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(Model.Investor))
	{
		<div>
			<label class="text-secondary">Inwestor:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.Investor</span>
			</div>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(Model.BuildingPermit))
	{
		<div>
			<label class="text-secondary">Pozwolenie na budowę:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.BuildingPermit</span>
			</div>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(Model.Description))
	{
		<div>
			<label class="text-secondary">Opis:</label>
			<div class="row font-weight-bold ml-2 text-primary">
				<span style="white-space: pre-line">@Model.Description</span>
			</div>
		</div>
	}

	<div>
		<label class="text-secondary">Data opracowania:</label>
		<div class="row font-weight-bold ml-2">
			@if (Model.DevelopmentDate.HasValue)
			{
				<span class="text-primary" style="white-space: pre-line">@Html.DisplayFor(x => x.DevelopmentDate)</span>
			}
			else
			{
				<span class="text-danger" style="white-space: pre-line">Do ustalenia</span>
			}
		</div>
	</div>

	@if (!(Model.Parts == null) && Model.Parts.Count > 0)
	{
		<div>
			<label class="text-secondary">Części:</label>
				@foreach (var item in Model.Parts)
				{
				<div class="row ml-2 text-primary">
					<span class="font-weight-bold" style="white-space: pre-line">@item.Title</span>
				</div>
					@foreach (var branch in item.Branches)
					{
					<div class="row">
						<div class="col my-auto ml-2 text-primary">@branch.Branch.ToString()</div>
					</div>
						@foreach (var role in branch.Roles)
						{
						<div class="row">
							<div class="col my-auto ml-2 text-primary">@_translatorFactory.GetTranslator().Translate(role.Role) : @role.License.Designer (@role.License.Content)</div>
						</div>
						}
					}
				}
		</div>
	}
</div>
