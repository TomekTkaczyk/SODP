@using SODP.UI.Pages.Shared.ViewModels;

@model ICollection<LicenseVM>

<div>
    @if (Model.Count > 0)
    {
        @foreach (var item in Model)
        {
            <div class="row">
                <div class="col col-md-4">
                    @item.Designer
                </div>
                <div class="col col-md-1">
                    @item.Content
                </div>
            </div>
        }
    }
    else
    {
        <p>Brak projektantów</p>
    }
</div>
